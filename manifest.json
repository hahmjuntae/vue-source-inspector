{
  "manifest_version": 3,
  "name": "Vue Source Inspector",
  "description": "Inspect Vue component source and related styles directly from Chrome DevTools.",
  "version": "1.0.2",
  "permissions": [
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/devtools/assets/fonts/geist-mono/GeistMono-Variable.woff2",
        "src/devtools/assets/fonts/geist-sans/Geist-Variable.woff2"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "icons": {
    "16": "src/assets/icons/icon-16.png",
    "32": "src/assets/icons/icon-32.png",
    "48": "src/assets/icons/icon-48.png",
    "128": "src/assets/icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "devtools_page": "src/devtools/devtools.html",
  "action": {
    "default_title": "Toggle Vue Source Inspector",
    "default_icon": {
      "16": "src/assets/icons/icon-16.png",
      "32": "src/assets/icons/icon-32.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Toggle Vue Source Inspector"
    }
  }
}
